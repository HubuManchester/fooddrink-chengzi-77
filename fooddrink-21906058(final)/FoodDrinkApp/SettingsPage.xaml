<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodDrinkApp.SettingsPage"
             Title="Settings"
             BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource DarkSurface}}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <!-- Accessibility Section Header -->
            <VerticalStackLayout Spacing="4">
                <Label Text="Accessibility settings" 
                       FontSize="22" 
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource DarkOnSurface}}"/>
                <Label Text="Large text takes effect immediately and remains active when switching pages."
                       FontSize="14"
                       TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource DarkOnSurfaceVariant}}"/>
            </VerticalStackLayout>

            <!-- Theme Mode Card -->
            <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}"
                    StrokeThickness="0"
                    Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16"/>
                </Border.StrokeShape>
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout>
                        <Label Text="Theme mode" 
                               FontSize="16" 
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource DarkOnSurface}}"/>
                    </VerticalStackLayout>
                    <Picker x:Name="ThemePicker"
                            Grid.Column="1"
                            Title="Select theme"
                            SelectedIndexChanged="OnThemeSelectedIndexChanged"
                            WidthRequest="160"
                            HorizontalOptions="End">
                        <Picker.Items>
                            <x:String>Use system theme</x:String>
                            <x:String>Light mode</x:String>
                            <x:String>Dark mode</x:String>
                        </Picker.Items>
                    </Picker>
                </Grid>
            </Border>

            <!-- Large Text Mode Card -->
            <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}"
                    StrokeThickness="0"
                    Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16"/>
                </Border.StrokeShape>
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout>
                        <Label Text="Large text mode" 
                               FontSize="16" 
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource DarkOnSurface}}"/>
                        <Label Text="Increase text size for accessibility demonstration."
                               FontSize="12"
                               TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource DarkOnSurfaceVariant}}"/>
                    </VerticalStackLayout>
                    <Switch x:Name="LargeTextSwitch"
                            Grid.Column="1"
                            HorizontalOptions="End"
                            VerticalOptions="Center"
                            Toggled="OnLargeTextToggled"/>
                </Grid>
            </Border>

            <!-- Large Text Preview Card -->
            <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}"
                    StrokeThickness="0"
                    Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">
                    <Label Text="Large text preview" 
                           FontSize="12"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource DarkPrimary}}"/>
                    <Label x:Name="PreviewLabel" 
                           Text="Turn on the switch to enlarge this preview and other page text."
                           FontSize="16"
                           TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource DarkOnSurface}}"/>
                </VerticalStackLayout>
            </Border>

            <!-- Success Message Toast (using Border instead of Label for corner radius) -->
            <Border x:Name="SuccessMessage"
                    StrokeThickness="0"
                    IsVisible="False"
                    HorizontalOptions="Center"
                    Padding="12,8">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="30"/>
                </Border.StrokeShape>
                <Border.Background>
                    <SolidColorBrush Color="{AppThemeBinding Light={StaticResource PrimaryContainer}, Dark={StaticResource DarkPrimaryContainer}}"/>
                </Border.Background>
                <Label Text="Theme preference updated."
                       FontSize="12"
                       TextColor="{AppThemeBinding Light={StaticResource OnPrimaryContainer}, Dark={StaticResource DarkOnPrimaryContainer}}"/>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>